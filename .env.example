# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Sepolia testnet RPC endpoint (get one free from Alchemy or Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Private key of the deployer/pool-operator wallet (no 0x prefix needed)
# Fund it with Sepolia ETH from https://sepoliafaucet.com
DEPLOYER_KEY=your_deployer_private_key_here

# Private key of the mailbox agent wallet
# This address must match the mailbox address set when opening a delivery request
MAILBOX_KEY=your_mailbox_private_key_here

# OpenAI API key — enables GPT-4o-mini explanations for bid ranking and mailbox confirm
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
